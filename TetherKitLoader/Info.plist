<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>

    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>

    <key>CFBundleIconFile</key>
    <string></string>

    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>

    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>

    <key>CFBundleShortVersionString</key>
    <string>1.0</string>

    <key>CFBundleVersion</key>
    <string>1</string>

    <!-- macOS 13 Ventura minimum -->
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>

    <!-- Single-window utility — no Dock icon needed during normal use. -->
    <key>LSUIElement</key>
    <false/>

    <!-- App requires macOS — not a Catalyst app. -->
    <key>NSHighResolutionCapable</key>
    <true/>

    <!--
        Privacy usage descriptions — required for App Store / notarization.
        The loader itself does not access any sensitive user data.
    -->
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2026 Prostec Labs. Original HoRNDIS © Joshua Wise, Mikhail Iakhiaev. GPLv3.</string>

    <!--
        The system extension the user will be prompted to approve.
        Shown in System Settings → Privacy & Security.
    -->
    <key>NSSystemExtensionUsageDescription</key>
    <string>TetherKit needs to install a system driver to enable network tethering from Android devices over USB.</string>
</dict>
</plist>
